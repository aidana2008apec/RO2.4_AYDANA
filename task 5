using System;
using System.Linq;

class Student
{
    private static int _idCounter = 1;

    public int StudentId { get; }
    public string Name { get; set; }
    private double _gpa;
    public double GPA
    {
        get => _gpa;
        set
        {
            if (value < 0.0 || value > 4.0)
                throw new ArgumentException("GPA must be between 0.0 and 4.0");
            _gpa = value;
        }
    }
    public string Faculty { get; set; }

    public Student(string name, double gpa, string faculty)
    {
        StudentId = _idCounter++;
        Name = name;
        GPA = gpa;
        Faculty = faculty;
    }

    public override string ToString()
    {
        return $"ID: {StudentId}, Name: {Name}, GPA: {GPA:F2}, Faculty: {Faculty}";
    }
}

class Registry
{
    private Student[] students = new Student[100];
    private int count = 0;

    public bool Add(Student student)
    {
        if (count >= 100)
        {
            Console.WriteLine("Registry is full.");
            return false;
        }
        students[count++] = student;
        return true;
    }

    public Student FindById(int id)
    {
        return students.Take(count).FirstOrDefault(s => s.StudentId == id);
    }

    public Student[] FindByName(string name)
    {
        return students
            .Take(count)
            .Where(s => s.Name.IndexOf(name, StringComparison.OrdinalIgnoreCase) >= 0)
            .ToArray();
    }

    public Student[] GetTopStudents(int n)
    {
        return students
            .Take(count)
            .OrderByDescending(s => s.GPA)
            .Take(n)
            .ToArray();
    }

    public void PrintAll()
    {
        if (count == 0)
        {
            Console.WriteLine("No students in registry.");
            return;
        }

        foreach (var s in students.Take(count))
        {
            Console.WriteLine(s);
        }
    }
}

class Program
{
    static void Main()
    {
        Registry registry = new Registry();

        while (true)
        {
            Console.WriteLine("\n--- Student Registry Menu ---");
            Console.WriteLine("1. Add Student");
            Console.WriteLine("2. Find by ID");
            Console.WriteLine("3. Find by Name");
            Console.WriteLine("4. Top Students");
            Console.WriteLine("5. Print All");
            Console.WriteLine("0. Exit");
            Console.Write("Choice: ");

            string choice = Console.ReadLine();

            try
            {
                switch (choice)
                {
                    case "1":
                        Console.Write("Name: ");
                        string name = Console.ReadLine();

                        Console.Write("GPA: ");
                        double gpa = double.Parse(Console.ReadLine());

                        Console.Write("Faculty: ");
                        string faculty = Console.ReadLine();

                        registry.Add(new Student(name, gpa, faculty));
                        Console.WriteLine("Student added.");
                        break;

                    case "2":
                        Console.Write("Enter ID: ");
                        int id = int.Parse(Console.ReadLine());

                        var studentById = registry.FindById(id);
                        Console.WriteLine(studentById != null ? studentById.ToString() : "Not found.");
                        break;

                    case "3":
                        Console.Write("Enter name: ");
                        string searchName = Console.ReadLine();

                        var results = registry.FindByName(searchName);
                        if (results.Length == 0)
                            Console.WriteLine("No matches.");
                        else
                            foreach (var s in results)
                                Console.WriteLine(s);
                        break;

                    case "4":
                        Console.Write("How many top students? ");
                        int n = int.Parse(Console.ReadLine());

                        var top = registry.GetTopStudents(n);
                        foreach (var s in top)
                            Console.WriteLine(s);
                        break;

                    case "5":
                        registry.PrintAll();
                        break;

                    case "0":
                        return;

                    default:
                        Console.WriteLine("Invalid choice.");
                        break;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
        }
    }
}
